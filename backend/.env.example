# Backend Environment Variables
# Copy this file to .env and fill in your real values.

# HuggingFace - get your token at https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_YOUR_TOKEN_HERE

# Model selection (defaults shown - change if needed)
STT_MODEL=openai/whisper-large-v3
LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3
TTS_MODEL=facebook/mms-tts-eng

# Behaviour - max characters of business-data context sent to the LLM
MAX_CONTEXT_CHARS=4000

# CORS - in production replace * with your frontend origin e.g.:
# ALLOWED_ORIGINS=["https://yourdomain.com"]
ALLOWED_ORIGINS=["*"]
